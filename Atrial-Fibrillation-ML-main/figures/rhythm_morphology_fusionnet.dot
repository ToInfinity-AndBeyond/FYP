digraph RhythmMorphologyFusionNet {
  graph [
    rankdir=TB,
    bgcolor="white",
    pad=0.25,
    nodesep=0.35,
    ranksep=0.55,
    splines=ortho,
    fontname="Helvetica"
  ];

  node [
    shape=box,
    style="rounded,filled",
    fontname="Helvetica",
    fontsize=12,
    margin="0.10,0.07",
    color="#334155",
    fillcolor="#f8fafc",
    fontcolor="#0f172a"
  ];

  edge [
    color="#475569",
    arrowsize=0.7,
    fontname="Helvetica",
    fontsize=10,
    fontcolor="#334155"
  ];

  input [label="30 s PPG segment\n3750 samples at 125 Hz", fillcolor="#e0f2fe"];
  preprocess [label="Band-pass filtering\nz-score normalisation", fillcolor="#e0f2fe"];
  sqi [label="SQI v2 gate\naccept / reject", shape=diamond, fillcolor="#fef3c7"];
  rejected [label="No-call / excluded\nunreliable segment", fillcolor="#fee2e2"];
  waveform [label="Accepted filtered waveform\nx", fillcolor="#e0f2fe"];
  feature_vector [label="Peak detection + SQI/rhythm features\n17-d vector f", fillcolor="#e0f2fe"];

  time_branch [
    label="Time-domain morphology branch\nConv1D stem -> multi-scale residual blocks\n2-layer Transformer + attention pooling\n64-d time embedding",
    fillcolor="#dcfce7"
  ];

  spec_branch [
    label="Spectral branch\nlog-magnitude STFT -> 2D CNN\nadaptive pooling\n64-d spectral embedding",
    fillcolor="#ede9fe"
  ];

  feat_branch [
    label="Feature branch\nMLP + LayerNorm over rhythm/SQI features\n64-d feature embedding",
    fillcolor="#ffedd5"
  ];

  concat [label="Concatenate branch embeddings\n192-d vector", fillcolor="#f1f5f9"];
  gate [label="Learned fusion gate", fillcolor="#f1f5f9"];
  classifier [label="Classifier head\nAF logit", fillcolor="#f1f5f9"];
  probability [label="sigmoid probability\np(AF given x, f)", fillcolor="#f1f5f9"];
  threshold [label="Validation-selected threshold\nsegment AF probability", fillcolor="#f1f5f9"];
  aggregation [label="Quality-weighted\nrecord-level aggregation", fillcolor="#f1f5f9"];
  decision [label="Record-level\nAF / SR decision", fillcolor="#e0e7ff"];

  input -> preprocess -> sqi;
  sqi -> rejected [label="rejected"];
  sqi -> waveform [label="accepted"];
  waveform -> feature_vector;

  waveform -> time_branch;
  waveform -> spec_branch;
  feature_vector -> feat_branch;

  { rank=same; time_branch; spec_branch; feat_branch; }

  time_branch -> concat;
  spec_branch -> concat;
  feat_branch -> concat;

  concat -> gate -> classifier -> probability -> threshold -> aggregation -> decision;
}
